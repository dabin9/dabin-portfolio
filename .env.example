# Tistory 블로그 (이름만 넣으면 https://<이름>.tistory.com 으로 자동 구성)
NEXT_PUBLIC_TISTORY_NAME=
# 또는 전체 URL 직접 지정
# NEXT_PUBLIC_TISTORY_URL=https://yourname.tistory.com

# 연락처 / 외부 링크
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_RESUME_URL=

# Admin (작업물 CRUD) — 비어있으면 /admin 로그인 불가
ADMIN_PASSWORD=
ADMIN_SECRET=

# GitHub 백엔드 (Vercel 배포에서 작업물 저장에 사용)
# 로컬 개발에서는 비워두면 src/data/projects.json 을 직접 fs 로 저장합니다.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
