# 외부 링크
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_EMAIL=
NEXT_PUBLIC_LINKEDIN_URL=

# Admin (작업물 CRUD) — 비어있으면 /admin 로그인 불가
ADMIN_PASSWORD=
ADMIN_SECRET=

# GitHub 백엔드 (Vercel 배포에서 작업물 저장에 사용)
# 로컬 개발에서는 비워두면 src/entities/project/data/projects.json 을 직접 fs 로 저장합니다.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# Vercel Blob (이미지 업로드 — Vercel 환경에서 자동 주입됨)
# 로컬 dev 는 비워두면 public/uploads 에 fs 로 저장.
BLOB_READ_WRITE_TOKEN=
